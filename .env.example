# Copy this file to .env.local for local development.
# On Vercel, set these under Project → Settings → Environment Variables.

# ── Database ──────────────────────────────────────────────────────────────────
# Supabase connection string (Session Pooler — supports Prisma $transaction).
# Find it in Supabase dashboard → Project Settings → Database → Connection String
# → Session mode (port 5432).
DATABASE_URL="postgresql://postgres.YOURREF:PASSWORD@aws-0-us-east-1.pooler.supabase.com:5432/postgres"

# ── Operator console ───────────────────────────────────────────────────────────
# Password to log in at /operator (the self-service clinic onboarding console).
OPERATOR_PASSWORD="change-me-strong-password"
# Secret used to sign operator session cookies (min 32 random chars).
OPERATOR_SECRET="change-me-random-64-char-secret-AAAAAAAAAAAAAAAAAAAAAAAAAAAAAA"

# ── Staff (admin) dashboard ────────────────────────────────────────────────────
# HMAC secret for per-clinic staff session cookies (min 32 random chars).
ADMIN_SECRET="change-me-random-64-char-secret-BBBBBBBBBBBBBBBBBBBBBBBBBBBBBB"
# Fallback password for the seeded demo clinic (no staffAuth hash set yet).
ADMIN_PASSWORD="letmein"

# ── Anthropic (Claude AI) ──────────────────────────────────────────────────────
# Without this the keyless fallback concierge runs (no streaming, limited reasoning).
ANTHROPIC_API_KEY=""

# ── ElevenLabs voice ──────────────────────────────────────────────────────────
# Without this the browser Web Speech API is used instead.
ELEVENLABS_API_KEY=""
# ELEVENLABS_VOICE_ID=""   # overrides per-clinic voice config
# ELEVENLABS_MODEL=""      # e.g. eleven_turbo_v2_5

# ── Email (Resend) ─────────────────────────────────────────────────────────────
# Without this confirmations are logged to the console (keyless fallback).
RESEND_API_KEY=""
# EMAIL_FROM="Sofia <noreply@yourdomain.com>"
# CLINIC_EMAIL="clinic@yourdomain.com"   # used as reply-to for contact form

# ── Appointment reminders cron ────────────────────────────────────────────────
# Set this and call /api/cron/reminders with Authorization: Bearer <CRON_SECRET>
# from a Vercel Cron Job or external scheduler.
CRON_SECRET=""

# ── Google Calendar sync ──────────────────────────────────────────────────────
# Without these the sync is a no-op (bookings still work, just not synced).
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REFRESH_TOKEN=""
# GOOGLE_CALENDAR_ID=""   # optional default calendar ID

# ── Multi-tenant default ──────────────────────────────────────────────────────
# Slug of the clinic that /admin redirects to and serves as the default tenant
# when no ?b=<slug> is present. Must match a seeded Business.slug.
BUSINESS_SLUG="paws-and-care"
